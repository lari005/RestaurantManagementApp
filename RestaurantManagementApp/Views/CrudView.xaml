<Window x:Class="RestaurantManagementApp.Views.CrudView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Gestionare Bază de Date (CRUD)" Height="450" Width="800" WindowStartupLocation="CenterScreen" Background="#F0F2F5">

    <Grid Margin="15">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="20"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="White" Padding="15" CornerRadius="8" BorderBrush="#DDD" BorderThickness="1">
            <StackPanel>
                <TextBlock Text="CATEGORII PREPARATE" FontSize="18" FontWeight="Bold" Margin="0,0,0,10" Foreground="#1976D2" HorizontalAlignment="Center"/>

                <DataGrid ItemsSource="{Binding Categorii}" SelectedItem="{Binding CategorieSelectata}" 
                          AutoGenerateColumns="False" IsReadOnly="True" Height="200" Margin="0,0,0,10">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Denumire Categorie" Binding="{Binding Nume}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>

                <TextBlock Text="Nume Categorie:" FontWeight="SemiBold"/>
                <TextBox Text="{Binding NumeCategorie, UpdateSourceTrigger=PropertyChanged}" Margin="0,5,0,15" Padding="5"/>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button Content="Adaugă" Command="{Binding AdaugaCategorieCommand}" Background="#4CAF50" Foreground="White" Width="90" Height="30" Margin="0,0,5,0" Cursor="Hand"/>
                    <Button Content="Modifică" Command="{Binding ModificaCategorieCommand}" Background="#FF9800" Foreground="White" Width="90" Height="30" Margin="0,0,5,0" Cursor="Hand"/>
                    <Button Content="Șterge" Command="{Binding StergeCategorieCommand}" Background="#F44336" Foreground="White" Width="90" Height="30" Cursor="Hand"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <Border Grid.Column="2" Background="White" Padding="15" CornerRadius="8" BorderBrush="#DDD" BorderThickness="1">
            <StackPanel>
                <TextBlock Text="ALERGENI" FontSize="18" FontWeight="Bold" Margin="0,0,0,10" Foreground="#D32F2F" HorizontalAlignment="Center"/>

                <DataGrid ItemsSource="{Binding Alergeni}" SelectedItem="{Binding AlergenSelectat}" 
                          AutoGenerateColumns="False" IsReadOnly="True" Height="200" Margin="0,0,0,10">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Denumire Alergen" Binding="{Binding Nume}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>

                <TextBlock Text="Nume Alergen:" FontWeight="SemiBold"/>
                <TextBox Text="{Binding NumeAlergen, UpdateSourceTrigger=PropertyChanged}" Margin="0,5,0,15" Padding="5"/>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button Content="Adaugă" Command="{Binding AdaugaAlergenCommand}" Background="#4CAF50" Foreground="White" Width="90" Height="30" Margin="0,0,5,0" Cursor="Hand"/>
                    <Button Content="Modifică" Command="{Binding ModificaAlergenCommand}" Background="#FF9800" Foreground="White" Width="90" Height="30" Margin="0,0,5,0" Cursor="Hand"/>
                    <Button Content="Șterge" Command="{Binding StergeAlergenCommand}" Background="#F44336" Foreground="White" Width="90" Height="30" Cursor="Hand"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Window>