<Window x:Class="RestaurantManagementApp.Views.CosView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Coșul de Cumpărături" Height="500" Width="600" WindowStartupLocation="CenterScreen">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Produse în coș:" FontSize="20" FontWeight="Bold" Margin="0,0,0,10"/>

        <DataGrid Grid.Row="1" ItemsSource="{Binding ProduseInCos}" AutoGenerateColumns="False" IsReadOnly="True" Margin="0,0,0,15">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Denumire" Binding="{Binding Denumire}" Width="*"/>
                <DataGridTextColumn Header="Pret (Lei)" Binding="{Binding Pret}" Width="100"/>
                <DataGridTemplateColumn Header="Acțiune">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="Sterge" Foreground="Red" Background="Transparent" BorderThickness="0" Cursor="Hand"
                                    Command="{Binding DataContext.StergeDinCosCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" 
                                    CommandParameter="{Binding}"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <Border Grid.Row="2" Background="#F0F0F0" Padding="15" CornerRadius="5">
            <StackPanel HorizontalAlignment="Right" Width="280">
                <StackPanel Orientation="Horizontal" Margin="0,2">
                    <TextBlock Text="Cost Mâncare: " Width="120"/>
                    <TextBlock Text="{Binding CostMancare, StringFormat={}{0:0.00} Lei}"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,2">
                    <TextBlock Text="Transport: " Width="120"/>
                    <TextBlock Text="{Binding CostTransport, StringFormat={}{0:0.00} Lei}"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,2">
                    <TextBlock Text="Discount Aplicat: " Width="120" Foreground="Green"/>
                    <TextBlock Text="{Binding DiscountAplicat, StringFormat=-{0:0.00} Lei}" Foreground="Green"/>
                </StackPanel>
                <Separator Margin="0,5"/>
                <StackPanel Orientation="Horizontal" Margin="0,5,0,10">
                    <TextBlock Text="TOTAL DE PLATĂ: " Width="120" FontWeight="Bold"/>
                    <TextBlock Text="{Binding CostTotal, StringFormat={}{0:0.00} Lei}" FontWeight="Bold" FontSize="16"/>
                </StackPanel>

                <TextBlock Text="Adresa de Livrare:" FontWeight="SemiBold" Margin="0,10,0,5"/>
                <TextBox Text="{Binding AdresaLivrareFinala, UpdateSourceTrigger=PropertyChanged}" 
                         TextWrapping="Wrap" AcceptsReturn="True" Height="60" Margin="0,0,0,15" Padding="5"/>

                <Button Content="Plasează Comanda" Command="{Binding PlaseazaComandaCommand}" 
                        Background="#4CAF50" Foreground="White" FontWeight="Bold" Height="35" Cursor="Hand"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>