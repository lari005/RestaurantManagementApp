<Window x:Class="RestaurantManagementApp.Views.MenuView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:RestaurantManagementApp.ViewModels"
        Title="Meniul Restaurantului" Height="600" Width="800" WindowStartupLocation="CenterScreen">

    <Window.DataContext>
        <vm:MenuViewModel />
    </Window.DataContext>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="Cauta mancare: " VerticalAlignment="Center" Margin="0,0,10,0" FontWeight="Bold"/>
            <TextBox Text="{Binding TextCautare, UpdateSourceTrigger=PropertyChanged}" Width="300" Padding="3"/>
        </StackPanel>

        <DataGrid Grid.Row="1" ItemsSource="{Binding PreparateAfisate}" AutoGenerateColumns="False" IsReadOnly="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Categorie" Binding="{Binding NumeCategorie}" Width="Auto"/>
                <DataGridTextColumn Header="Denumire" Binding="{Binding Denumire}" Width="*"/>
                <DataGridTextColumn Header="Cantitate/Portie" Binding="{Binding CantitatePortie}" Width="Auto"/>
                <DataGridTextColumn Header="Pret (Lei)" Binding="{Binding Pret}" Width="Auto"/>

                <DataGridTemplateColumn Header="Stare">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding IsDisponibil, Converter={StaticResource BooleanToStatusConverter}}" 
                                       Foreground="{Binding IsDisponibil, Converter={StaticResource BooleanToColorConverter}}"
                                       FontWeight="Bold"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>