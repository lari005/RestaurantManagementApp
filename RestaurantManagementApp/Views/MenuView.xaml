<Window x:Class="RestaurantManagementApp.Views.MenuView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:RestaurantManagementApp.ViewModels"
        Title="Meniul Restaurantului" Height="600" Width="800" WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </Window.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="Căutați în meniu: " VerticalAlignment="Center" Margin="0,0,10,0" FontWeight="Bold"/>
            <TextBox Text="{Binding TextCautare, UpdateSourceTrigger=PropertyChanged}" Width="300" Padding="3"/>

            <Button Content="Deschide Panou Angajat" Command="{Binding DeschidePanouAngajatCommand}" 
                    Visibility="{Binding EsteAngajatLogat, Converter={StaticResource BoolToVis}}"
                    Background="#9C27B0" Foreground="White" FontWeight="Bold" Width="180" Margin="30,0,0,0" Cursor="Hand"/>
        </StackPanel>

        <DataGrid Grid.Row="1" ItemsSource="{Binding PreparateAfisate}" 
                  SelectedItem="{Binding PreparatSelectat}" 
                  AutoGenerateColumns="False" IsReadOnly="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Categorie" Binding="{Binding NumeCategorie}" Width="Auto"/>
                <DataGridTemplateColumn Header="Poză" Width="70">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Image Source="{Binding PrimaImagine}" Width="50" Height="50" Stretch="UniformToFill" Margin="2"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="Denumire" Binding="{Binding Denumire}" Width="*"/>
                <DataGridTextColumn Header="Cantitate/Portie" Binding="{Binding CantitatePortie}" Width="Auto"/>
                <DataGridTextColumn Header="Preț (Lei)" Binding="{Binding Pret}" Width="Auto"/>

                <DataGridTemplateColumn Header="Stare">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding IsDisponibil, Converter={StaticResource BooleanToStatusConverter}}" 
                                       Foreground="{Binding IsDisponibil, Converter={StaticResource BooleanToColorConverter}}"
                                       FontWeight="Bold"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0"
                 Visibility="{Binding EsteClientLogat, Converter={StaticResource BoolToVis}}">

            <Button Content="Istoric Comenzi" Command="{Binding DeschideIstoricCommand}" 
                 Background="#2196F3" Foreground="White" FontWeight="Bold" Width="140" Height="35" Margin="0,0,20,0" Cursor="Hand"/>

            <TextBlock Text="Cantitate:" VerticalAlignment="Center" Margin="0,0,10,0" FontWeight="Bold"/>
            <TextBox Text="{Binding CantitateSelectata, UpdateSourceTrigger=PropertyChanged}" Width="50" Margin="0,0,20,0" TextAlignment="Center" VerticalContentAlignment="Center"/>

            <Button Content="Adaugă în Coș" Command="{Binding AdaugaInCosCommand}" 
                 Background="#FF9800" Foreground="White" FontWeight="Bold" Width="120" Height="35" Cursor="Hand"/>

            <Button Content="Vezi Coșul (Finalizează)" Command="{Binding DeschideCosCommand}" 
                 Background="#4CAF50" Foreground="White" FontWeight="Bold" Width="170" Height="35" Margin="15,0,0,0" Cursor="Hand"/>
        </StackPanel>

    </Grid>
</Window>