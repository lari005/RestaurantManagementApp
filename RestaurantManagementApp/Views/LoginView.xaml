<Window x:Class="RestaurantManagementApp.Views.LoginView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:RestaurantManagementApp.ViewModels"
        Title="Autentificare Restaurant" 
        Width="450" 
        SizeToContent="Height" 
        WindowStartupLocation="CenterScreen"
        Background="#F0F2F5">

    <Window.DataContext>
        <vm:LoginViewModel />
    </Window.DataContext>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="30">
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="Autentificare" FontSize="28" FontWeight="Bold" 
                           HorizontalAlignment="Center" Margin="0,0,0,25" Foreground="#333"/>

                <TextBlock Text="Email:" FontWeight="SemiBold" Margin="0,0,0,5"/>
                <TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}" 
                         Margin="0,0,0,15" Padding="8" FontSize="14"/>

                <TextBlock Text="Parolă:" FontWeight="SemiBold" Margin="0,0,0,5"/>
                <TextBox Text="{Binding Parola, UpdateSourceTrigger=PropertyChanged}" 
                         Margin="0,0,0,20" Padding="8" FontSize="14"/>

                <Button Content="Autentificare" 
                        Command="{Binding LoginCommand}" 
                        CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"
                        Height="45" Background="#4CAF50" Foreground="White" 
                        FontWeight="Bold" FontSize="16" Margin="0,0,0,10" Cursor="Hand"/>

                <Button Content="Continuă ca Oaspete (Neautentificat)" 
                        Command="{Binding ContinuaCaOaspeteCommand}" 
                        CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"
                        Height="35" Background="#2196F3" Foreground="White" 
                        Margin="0,0,0,20" Cursor="Hand"/>

                <TextBlock HorizontalAlignment="Center" Margin="0,10,0,0">
                    <Run Text="Nu ai cont? "/>
                    <Hyperlink Foreground="Blue" FontWeight="Bold">Înregistrează-te acum</Hyperlink>
                </TextBlock>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Window>