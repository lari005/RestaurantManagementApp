<Window x:Class="RestaurantManagementApp.Views.ClientPanelView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Panoul Clientului - Istoric Comenzi" Height="450" Width="950" WindowStartupLocation="CenterScreen">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Istoricul Comenzilor Tale" FontSize="22" FontWeight="Bold" Margin="0,0,0,15" Foreground="#333"/>

        <DataGrid Grid.Row="1" ItemsSource="{Binding ComenziClient}" AutoGenerateColumns="False" IsReadOnly="True" HeadersVisibility="Column">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Data și Ora" Binding="{Binding DataComanda, StringFormat={}{0:dd/MM/yyyy HH:mm}}" Width="120"/>
                <DataGridTextColumn Header="Cod Unic Comandă" Binding="{Binding CodUnic}" Width="150"/>
                <DataGridTextColumn Header="Produse (Bucăți)" Binding="{Binding ProduseFormatate}" Width="*"/>
                <DataGridTextColumn Header="Total de Plată" Binding="{Binding CostTotal, StringFormat={}{0:0.00} Lei}" Width="100"/>
                <DataGridTextColumn Header="Stare" Binding="{Binding Stare}" Width="90"/>
                <DataGridTextColumn Header="Livrare Est." Binding="{Binding OraEstimativaLivrare, StringFormat={}{0:HH:mm}}" Width="90"/>

                <DataGridTemplateColumn Header="Acțiuni" Width="100">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="Anulează" 
                                    Command="{Binding DataContext.AnuleazaComandaCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" 
                                    CommandParameter="{Binding}"
                                    IsEnabled="{Binding PoateFiAnulata}"
                                    Background="#F44336" Foreground="White" Cursor="Hand" Padding="5,2" FontWeight="Bold"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>